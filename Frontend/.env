# Local development
VITE_API_BASE_URL=http://localhost:3232

# Production - Direct access bypassing Nginx
# VITE_API_BASE_URL=http://13.233.131.46:3232

# ============================================
# SUBSCRIPTION FEATURE FLAGS (May 26, 2026)
# ============================================
# Set to 'true' to enable subscription UI
# Keep 'false' to maintain current behavior
# Default: false (all features disabled)

# Show subscription status card on dashboard
VITE_SUBSCRIPTION_UI_ENABLED=true

# Show upgrade button and promotion
VITE_SUBSCRIPTION_UPGRADE_BUTTON_ENABLED=true

# Show booking information filtering notice
VITE_SUBSCRIPTION_BOOKING_FILTER_NOTICE_ENABLED=true

# Show trial countdown in dashboard
VITE_SUBSCRIPTION_TRIAL_COUNTDOWN_ENABLED=true
