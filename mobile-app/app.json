{
  "expo": {
    "name": "GoEventify",
    "slug": "goeventify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mobile_logo.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/mobile_logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "package": "com.adrs.goeventify"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mobile_logo.png"
    },
    "splash": {
      "image": "./assets/images/mobile_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GoEventify to access your photos to set profile image.",
          "cameraPermission": "Allow GoEventify to use your camera to capture profile image."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GoEventify to use your camera to capture profile image."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mobile_logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E6F4FE",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9425b6bb-224f-4a56-9e9e-5dbfdec1e237"
      }
    },
    "owner": "adrstechnos-organization"
  }
}
